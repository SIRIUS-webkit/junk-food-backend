# Local development — copy to .env.local (or merge into .env)
# Run: npm run dev

APP_ENV=local
NODE_ENV=development
PORT=4000

# Docker Postgres (host port 5433) or local Postgres
DATABASE_URL=postgresql://junkshop:junkshop@localhost:5433/junkshop?schema=public
DIRECT_URL=postgresql://junkshop:junkshop@localhost:5433/junkshop?schema=public

JWT_ACCESS_SECRET=dev_access_secret
JWT_REFRESH_SECRET=dev_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

SUPER_ADMIN_EMAIL=admin@junkshop.local
SUPER_ADMIN_PHONE=0900000000
SUPER_ADMIN_PASSWORD=Admin@12345
SEED_DEMO_ENTITY=true
