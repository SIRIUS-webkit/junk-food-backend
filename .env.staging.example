# Staging — set these on Render service "junkshop-api-staging"
# Use a separate Supabase project (staging database)

APP_ENV=staging
NODE_ENV=production

# Supabase STAGING — pooler (6543) + pgbouncer=true
DATABASE_URL=postgresql://postgres.[STAGING_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
# Supabase STAGING — direct (5432)
DIRECT_URL=postgresql://postgres.[STAGING_REF]:[PASSWORD]@aws-0-[REGION].supabase.co:5432/postgres

JWT_ACCESS_SECRET=<long-random-string>
JWT_REFRESH_SECRET=<long-random-string>
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

SUPER_ADMIN_EMAIL=admin@staging.example.com
SUPER_ADMIN_PHONE=0900000001
SUPER_ADMIN_PASSWORD=<strong-password>
SEED_DEMO_ENTITY=true
