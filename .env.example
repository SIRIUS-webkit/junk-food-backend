# Server
NODE_ENV=development
PORT=4000

# Database (used by Prisma & the app). When running inside docker-compose
# the host is the service name "db"; locally it is "localhost".
DATABASE_URL=postgresql://junkshop:junkshop@localhost:5432/junkshop?schema=public

# Postgres container settings (used by docker-compose)
POSTGRES_USER=junkshop
POSTGRES_PASSWORD=junkshop
POSTGRES_DB=junkshop

# JWT
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Super admin seed credentials
SUPER_ADMIN_EMAIL=admin@junkshop.local
SUPER_ADMIN_PHONE=0900000000
SUPER_ADMIN_PASSWORD=Admin@12345
