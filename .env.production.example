# Production — set these on Render service "junkshop-api-prod"
# Use a separate Supabase project (production database)

APP_ENV=production
NODE_ENV=production

# Supabase PRODUCTION — pooler (6543) + pgbouncer=true
DATABASE_URL=postgresql://postgres.[PROD_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
# Supabase PRODUCTION — direct (5432)
DIRECT_URL=postgresql://postgres.[PROD_REF]:[PASSWORD]@aws-0-[REGION].supabase.co:5432/postgres

JWT_ACCESS_SECRET=<long-random-string>
JWT_REFRESH_SECRET=<long-random-string>
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

SUPER_ADMIN_EMAIL=admin@yourcompany.com
SUPER_ADMIN_PHONE=0900000000
SUPER_ADMIN_PASSWORD=<strong-password>
SEED_DEMO_ENTITY=false
